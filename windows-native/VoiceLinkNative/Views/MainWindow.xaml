<Window x:Class="VoiceLinkNative.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceLink v1.0.0"
        Height="760"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#131722"
        Foreground="#F4F1EA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E2636" CornerRadius="16" Padding="20" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="VoiceLink" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="Desktop shell with live auth, server, and licensing state."
                               Margin="0,6,0,0"
                               Foreground="#C2C7D1"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding AuthSummary}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding ServerSummary}" Margin="0,6,0,0" Foreground="#C2C7D1" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1A2030" CornerRadius="14" Padding="16" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Auth" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding AuthSummary}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding AuthDetail}" Margin="0,6,0,0" Foreground="#B7BDC9" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#1A2030" CornerRadius="14" Padding="16" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Server" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ServerSummary}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding ServerDetail}" Margin="0,6,0,0" Foreground="#B7BDC9" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#1A2030" CornerRadius="14" Padding="16">
                <StackPanel>
                    <TextBlock Text="License" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding LicenseSummary}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding LicenseDetail}" Margin="0,6,0,0" Foreground="#B7BDC9" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#171D2B" CornerRadius="14" Padding="16" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Actions" FontSize="18" FontWeight="SemiBold"/>

                    <Button Content="Open Servers" Click="OpenServers_Click" Margin="0,16,0,0" Height="36"/>
                    <Button Content="Open Settings" Click="OpenSettings_Click" Margin="0,10,0,0" Height="36"/>
                    <Button Content="Refresh License" Click="RefreshLicense_Click" Margin="0,10,0,0" Height="36"/>
                    <Button Content="Activate This Device" Click="ActivateDevice_Click" Margin="0,10,0,0" Height="36"/>
                    <Button Content="Logout" Click="Logout_Click" Margin="0,10,0,0" Height="36"/>

                    <Separator Margin="0,16,0,16"/>

                    <TextBlock Text="Latest Notice" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding LatestNotice}" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="#C2C7D1"/>
                    <TextBlock Text="{Binding ErrorMessage}" Margin="0,12,0,0" TextWrapping="Wrap" Foreground="#FF9D92"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#171D2B" CornerRadius="14" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Recent Machines" FontSize="18" FontWeight="SemiBold"/>
                        <ListView Grid.Row="1" Margin="0,12,0,0" ItemsSource="{Binding RecentMachines}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Machine" Width="180" DisplayMemberBinding="{Binding Name}" />
                                    <GridViewColumn Header="Platform" Width="90" DisplayMemberBinding="{Binding Platform}" />
                                    <GridViewColumn Header="State" Width="100" DisplayMemberBinding="{Binding State}" />
                                    <GridViewColumn Header="Last Seen" Width="180" DisplayMemberBinding="{Binding LastSeen}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#171D2B" CornerRadius="14" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Activated Devices" FontSize="18" FontWeight="SemiBold"/>
                        <ListView Grid.Row="1" Margin="0,12,0,0" ItemsSource="{Binding Devices}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Device" Width="220" DisplayMemberBinding="{Binding Name}" />
                                    <GridViewColumn Header="Platform" Width="100" DisplayMemberBinding="{Binding Platform}" />
                                    <GridViewColumn Header="Activated" Width="180" DisplayMemberBinding="{Binding ActivatedAt}" />
                                    <GridViewColumn Header="Last Seen" Width="180" DisplayMemberBinding="{Binding LastSeen}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
