<Window x:Class="VoiceLinkNative.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Login to VoiceLink"
        Height="760" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,20">
            <TextBlock Text="Login to VoiceLink"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Use Mastodon, email verification, or an admin invite."
                       FontSize="14"
                       Foreground="#999999"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="#202038" CornerRadius="10" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Mastodon"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Authenticate with a Mastodon instance."
                                   FontSize="12"
                                   Foreground="#9aa0b8"
                                   Margin="0,4,0,12"/>
                        <TextBlock Text="Instance"
                                   Foreground="White"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding MastodonInstance, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10"
                                 Margin="0,0,0,10"/>
                        <Button Content="Login with Mastodon"
                                Padding="12,10"
                                Click="LoginButton_Click"
                                IsEnabled="{Binding CanLogin}"/>
                        <StackPanel Margin="0,12,0,0"
                                    Visibility="{Binding ShowAuthCodeInput, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Authorization Code"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox Text="{Binding AuthorizationCode, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     Margin="0,0,0,10"/>
                            <Button Content="Complete Mastodon Login"
                                    Padding="12,10"
                                    Click="CompleteLoginButton_Click"
                                    IsEnabled="{Binding CanCompleteLogin}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#202038" CornerRadius="10" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Email / Username"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Request a verification code and sign in without Mastodon."
                                   FontSize="12"
                                   Foreground="#9aa0b8"
                                   Margin="0,4,0,12"/>
                        <TextBlock Text="Email"
                                   Foreground="White"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10"
                                 Margin="0,0,0,10"/>
                        <Button Content="Send Verification Code"
                                Padding="12,10"
                                Click="RequestEmailCodeButton_Click"
                                IsEnabled="{Binding CanRequestEmailCode}"/>
                        <StackPanel Margin="0,12,0,0"
                                    Visibility="{Binding ShowEmailCodeInput, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Verification Code"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox Text="{Binding VerificationCode, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     Margin="0,0,0,10"/>
                            <Button Content="Verify and Sign In"
                                    Padding="12,10"
                                    Click="VerifyEmailCodeButton_Click"
                                    IsEnabled="{Binding CanVerifyEmailCode}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#202038" CornerRadius="10" Padding="18">
                    <StackPanel>
                        <TextBlock Text="Admin Invite"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Activate an owner/admin invite from the server."
                                   FontSize="12"
                                   Foreground="#9aa0b8"
                                   Margin="0,4,0,12"/>
                        <TextBlock Text="Invite Token"
                                   Foreground="White"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding InviteToken, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10"
                                 Margin="0,0,0,10"/>
                        <TextBlock Text="Server URL"
                                   Foreground="White"
                                   Margin="0,0,0,6"/>
                        <TextBox Text="{Binding InviteServerUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10"
                                 Margin="0,0,0,10"/>
                        <Button Content="Load Invite"
                                Padding="12,10"
                                Click="LoadInviteButton_Click"
                                IsEnabled="{Binding CanLoadInvite}"/>

                        <StackPanel Margin="0,12,0,0"
                                    Visibility="{Binding ShowInviteActivation, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Email"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox Text="{Binding InviteEmail, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     Margin="0,0,0,10"/>
                            <TextBlock Text="Username"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox Text="{Binding InviteUsername, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     Margin="0,0,0,10"/>
                            <TextBlock Text="Display Name"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <TextBox Text="{Binding InviteDisplayName, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10"
                                     Margin="0,0,0,10"/>
                            <TextBlock Text="Password"
                                       Foreground="White"
                                       Margin="0,0,0,6"/>
                            <PasswordBox x:Name="InvitePasswordBox"
                                         Padding="10"
                                         PasswordChanged="InvitePasswordBox_PasswordChanged"
                                         Margin="0,0,0,10"/>
                            <Button Content="Activate Admin Invite"
                                    Padding="12,10"
                                    Click="ActivateInviteButton_Click"
                                    IsEnabled="{Binding CanActivateInvite}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <ProgressBar Height="4"
                         IsIndeterminate="True"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#6fb4ff"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap"
                       Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,14,0,0">
            <Border Background="#8f2f3a"
                    CornerRadius="8"
                    Padding="12"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="White"
                           TextWrapping="Wrap"/>
            </Border>
            <Button Content="Back to Main Menu"
                    HorizontalAlignment="Center"
                    Margin="0,14,0,0"
                    Padding="12,8"
                    Click="BackButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
