<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="VoiceLink_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:VoiceLink_WinUI"
    xmlns:models="using:VoiceLink_WinUI.Services"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="SectionTitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Page.Resources>

    <Grid Padding="20" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Name="LiveRegion"
            Height="1"
            Width="1"
            Opacity="0"
            AutomationProperties.LiveSetting="Assertive"
            AutomationProperties.Name="VoiceLink announcements" />

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock
                Text="VoiceLink"
                FontSize="24"
                FontWeight="SemiBold"
                AutomationProperties.HeadingLevel="Level1" />
            <TextBlock
                Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                AutomationProperties.LiveSetting="Polite"
                AutomationProperties.Name="Connection status" />
        </StackPanel>

        <CommandBar Grid.Row="1" DefaultLabelPosition="Right">
            <AppBarButton
                Icon="Contact"
                Label="Connect main"
                Click="ConnectMain_Click"
                AutomationProperties.Name="Connect to main VoiceLink server" />
            <AppBarButton
                Icon="Home"
                Label="Connect local"
                Click="ConnectLocal_Click"
                AutomationProperties.Name="Connect to local VoiceLink server" />
            <AppBarButton
                Icon="Refresh"
                Label="Refresh rooms"
                Click="RefreshRooms_Click" />
            <AppBarButton
                Icon="Cancel"
                Label="Disconnect"
                Click="Disconnect_Click" />
        </CommandBar>

        <NavigationView
            Grid.Row="2"
            x:Name="RootNavigation"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            SelectionChanged="RootNavigation_SelectionChanged"
            AutomationProperties.Name="VoiceLink sections">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Servers" Icon="World" Tag="Servers" />
                <NavigationViewItem Content="Rooms" Icon="People" Tag="Rooms" />
                <NavigationViewItem Content="Messages" Icon="Message" Tag="Messages" />
                <NavigationViewItem Content="Admin" Icon="Setting" Tag="Admin" />
                <NavigationViewItem Content="Settings" Icon="Equalizer" Tag="Settings" />
            </NavigationView.MenuItems>

            <Grid Padding="12">
                <Grid x:Name="ServersPanel" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Servers" Style="{StaticResource SectionTitleText}" />
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                        <TextBox
                            Header="Server URL"
                            Text="{x:Bind ViewModel.ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Width="420"
                            AutomationProperties.HelpText="Enter a VoiceLink server URL, then choose connect custom." />
                        <Button
                            Content="Connect custom"
                            Click="ConnectCustom_Click"
                            VerticalAlignment="Bottom" />
                    </StackPanel>
                    <ListView
                        Grid.Row="2"
                        ItemsSource="{x:Bind ViewModel.Servers}"
                        IsItemClickEnabled="True"
                        ItemClick="Server_ItemClick"
                        SelectionMode="Single"
                        AutomationProperties.Name="Known VoiceLink servers">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Url}" />
                                    <TextBlock Text="{Binding Description}" Opacity="0.75" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <Grid x:Name="RoomsPanel" Visibility="Collapsed" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Rooms" Style="{StaticResource SectionTitleText}" />
                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Rooms}"
                        SelectedItem="{x:Bind ViewModel.SelectedRoom, Mode=TwoWay}"
                        SelectionMode="Single"
                        AutomationProperties.Name="Available rooms">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Description}" />
                                    <TextBlock Text="{Binding Users}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button Grid.Row="2" Content="Join selected room" Click="JoinRoom_Click" />
                </Grid>

                <Grid x:Name="MessagesPanel" Visibility="Collapsed" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Messages" Style="{StaticResource SectionTitleText}" />
                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Messages}"
                        AutomationProperties.Name="Room and direct messages" />
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                        <TextBox
                            Header="Message"
                            Text="{x:Bind ViewModel.MessageText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Width="420"
                            AcceptsReturn="False" />
                        <Button Content="Send" Click="SendMessage_Click" VerticalAlignment="Bottom" />
                    </StackPanel>
                </Grid>

                <ScrollViewer x:Name="AdminPanel" Visibility="Collapsed">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Admin" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="Server stats, users, rooms, API sync, federation, and background streams will use the existing admin API service in the next migration pass." TextWrapping="Wrap" />
                        <Button Content="Check admin status" IsEnabled="False" />
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="SettingsPanel" Visibility="Collapsed">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Settings" Style="{StaticResource SectionTitleText}" />
                        <ToggleSwitch Header="Announce status changes through NVDA when available" IsOn="True" />
                        <ToggleSwitch Header="Start local VoiceLink API when connecting to local server" IsOn="True" />
                        <ComboBox Header="Audio input device" PlaceholderText="System default" Width="320" />
                        <ComboBox Header="Audio output device" PlaceholderText="System default" Width="320" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </NavigationView>
    </Grid>
</Page>
